{
  "version": 1,
  "families": {
    "audio": {
      "description": "Audio compression profiles for size-first delivery.",
      "mime_prefixes": ["audio/"],
      "extensions": ["mp3", "m4a", "aac", "wav", "flac", "ogg", "oga", "opus", "weba", "mka", "aiff", "aif", "alac", "wma"],
      "profiles": {
        "balanced": {
          "target": "Small download size with acceptable speech/music quality.",
          "container": "mp3",
          "codec": "libmp3lame",
          "bitrate": "128k",
          "quality": 4,
          "strip_metadata": true
        },
        "small": {
          "target": "Aggressive size reduction for mobile delivery.",
          "container": "mp3",
          "codec": "libmp3lame",
          "bitrate": "96k",
          "quality": 6,
          "strip_metadata": true
        }
      }
    },
    "video": {
      "description": "Video compression profiles for web and storage savings.",
      "mime_prefixes": ["video/"],
      "extensions": ["mp4", "mkv", "mov", "webm", "avi", "m4v", "mpg", "mpeg", "flv", "wmv", "ogv", "ts", "m2ts", "mts", "vob", "3gp", "3g2"],
      "profiles": {
        "balanced": {
          "target": "Web-friendly output with moderate quality retention.",
          "container": "mp4",
          "video_codec": "libx264",
          "audio_codec": "aac",
          "crf": 28,
          "max_width": 1280,
          "max_height": 720,
          "max_fps": 30,
          "strip_metadata": true
        },
        "small": {
          "target": "Smaller files for preview and sync.",
          "container": "mp4",
          "video_codec": "libx264",
          "audio_codec": "aac",
          "crf": 32,
          "max_width": 960,
          "max_height": 540,
          "max_fps": 24,
          "strip_metadata": true
        }
      }
    },
    "image": {
      "description": "Image compression profiles for storage and web previews.",
      "mime_prefixes": ["image/"],
      "extensions": ["jpg", "jpeg", "png", "webp", "avif", "gif", "bmp", "tiff", "tif", "ico", "svg", "heic", "heif", "jp2", "j2k", "jpf", "jpx", "tga"],
      "profiles": {
        "balanced": {
          "target": "Keep visual quality while shrinking file size.",
          "format": "webp",
          "quality": 82,
          "max_width": 1920,
          "max_height": 1920,
          "strip_metadata": true
        },
        "small": {
          "target": "Aggressive compression for thumbnails and sync.",
          "format": "webp",
          "quality": 72,
          "max_width": 1280,
          "max_height": 1280,
          "strip_metadata": true
        }
      }
    },
    "document": {
      "description": "Office and text documents converted through LibreOffice.",
      "mime_prefixes": [
        "application/msword",
        "application/vnd.openxmlformats-officedocument.wordprocessingml",
        "application/vnd.oasis.opendocument.text",
        "application/rtf",
        "text/html"
      ],
      "extensions": ["docx", "doc", "docm", "dot", "dotx", "dotm", "odt", "rtf", "html", "htm", "mht", "mhtml"],
      "profiles": {
        "balanced": { "target": "Document conversion.", "strip_metadata": false },
        "small": { "target": "Document conversion.", "strip_metadata": false }
      }
    },
    "spreadsheet": {
      "description": "Spreadsheet files converted through LibreOffice.",
      "mime_prefixes": [
        "application/vnd.ms-excel",
        "application/vnd.openxmlformats-officedocument.spreadsheetml",
        "application/vnd.oasis.opendocument.spreadsheet",
        "text/csv"
      ],
      "extensions": ["xlsx", "xls", "xlsm", "xlt", "xltx", "xltm", "ods", "csv", "tsv"],
      "profiles": {
        "balanced": { "target": "Spreadsheet conversion.", "strip_metadata": false },
        "small": { "target": "Spreadsheet conversion.", "strip_metadata": false }
      }
    },
    "presentation": {
      "description": "Presentation files converted through LibreOffice.",
      "mime_prefixes": [
        "application/vnd.ms-powerpoint",
        "application/vnd.openxmlformats-officedocument.presentationml",
        "application/vnd.oasis.opendocument.presentation"
      ],
      "extensions": ["pptx", "ppt", "pptm", "pps", "ppsx", "ppsm", "pot", "potx", "potm", "odp"],
      "profiles": {
        "balanced": { "target": "Presentation conversion.", "strip_metadata": false },
        "small": { "target": "Presentation conversion.", "strip_metadata": false }
      }
    },
    "pdf": {
      "description": "PDF conversion and text extraction.",
      "mime_prefixes": ["application/pdf"],
      "extensions": ["pdf"],
      "profiles": {
        "balanced": { "target": "PDF conversion.", "strip_metadata": false },
        "small": { "target": "PDF conversion.", "strip_metadata": false }
      }
    },
    "text": {
      "description": "Plain text files.",
      "mime_prefixes": ["text/plain"],
      "extensions": ["txt", "md", "markdown", "log", "json", "xml", "yaml", "yml"],
      "profiles": {
        "balanced": { "target": "Text conversion.", "strip_metadata": false },
        "small": { "target": "Text conversion.", "strip_metadata": false }
      }
    }
  },
  "fallback": {
    "family": "archive",
    "policy": "lossless_archive"
  }
}
